# Resend API key used to send form submission emails from the Cloudflare Worker.
# For local dev (astro dev / wrangler dev), put this in .dev.vars instead — Astro
# reads Cloudflare bindings via locals.runtime.env, not process.env.
# For production, set it with: wrangler secret put RESEND_API_KEY
RESEND_API_KEY=

# Optional. Defaults to "Glasstech Website <onboarding@resend.dev>", Resend's
# shared test sender that requires no domain verification but can only deliver
# to the email address your Resend account is registered with. Once
# glasstech.com is verified in Resend, set this to e.g.
# "Glasstech Website <forms@glasstech.com>".
FROM_EMAIL=
