    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@fontsource/archivo": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
