---
import { mainNav } from '../data/navigation';
import Wordmark from './Wordmark.astro';
import MobileNavItem from './MobileNavItem.astro';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="sticky top-0 z-50 bg-white/85 backdrop-blur-md border-b border-slate-200">
  <div class="container-x">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex-shrink-0 rounded-lg" aria-label="Glasstech, Inc. — Home">
        <Wordmark brand />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">
        {mainNav.map((item) => (
          item.children ? (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-1 px-3 py-2 text-[0.9rem] font-medium rounded-md transition-colors',
                  isActive(item.href) ? 'text-ink' : 'text-slate-500 hover:text-ink',
                ]}
              >
                {item.label}
                <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
              </a>
              {/* hover/focus underline */}
              <span class:list={['pointer-events-none absolute left-3 right-7 -bottom-px h-px bg-ink transition-transform duration-200 origin-left', isActive(item.href) ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100']}></span>

              <div class="absolute right-0 top-full pt-3 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 transition-all duration-200">
                <div class="bg-white rounded-2xl shadow-[0_18px_50px_-12px_rgba(22,32,44,0.22)] border border-slate-200 p-5">
                  {item.label === 'Products' ? (
                    <div class="grid grid-cols-2 gap-x-8 gap-y-5 min-w-[440px]">
                      {item.children.map((cat) => (
                        <div>
                          <a href={cat.href} class="block text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-brand hover:text-ink mb-2.5">{cat.label}</a>
                          <div class="space-y-0.5">
                            {cat.children?.map((sub) => (
                              <a href={sub.href} class="block text-sm text-slate-500 hover:text-ink py-0.5 transition-colors">{sub.label}</a>
                            ))}
                          </div>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="min-w-[220px] space-y-0.5">
                      {item.children.map((child) => (
                        <a href={child.href} class="block px-3 py-2 text-sm text-slate-500 hover:text-ink hover:bg-slate-50 rounded-lg transition-colors">{child.label}</a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
          ) : (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  'block px-3 py-2 text-[0.9rem] font-medium rounded-md transition-colors',
                  isActive(item.href) ? 'text-ink' : 'text-slate-500 hover:text-ink',
                ]}
              >
                {item.label}
              </a>
              <span class:list={['pointer-events-none absolute left-3 right-3 -bottom-px h-px bg-ink transition-transform duration-200 origin-left', isActive(item.href) ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100']}></span>
            </div>
          )
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden -mr-2 p-2 rounded-lg text-ink hover:bg-slate-100 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav drawer -->
  <div id="mobile-nav" class="lg:hidden hidden fixed inset-0 z-50">
    <div id="mobile-nav-backdrop" class="absolute inset-0 bg-ink/40 backdrop-blur-sm"></div>
    <div class="absolute inset-y-0 right-0 flex h-screen w-[88%] max-w-sm flex-col bg-white shadow-2xl">
      <div class="flex shrink-0 items-center justify-between px-5 h-16 border-b border-slate-200">
        <Wordmark brand />
        <button id="mobile-menu-close" class="-mr-2 p-2 rounded-lg text-ink hover:bg-slate-100" aria-label="Close menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <nav class="flex-1 overflow-y-auto px-3 py-4" aria-label="Mobile navigation">
        {mainNav.map((item) => (
          <div class="border-b border-slate-100 last:border-0 py-1">
            <MobileNavItem item={item} />
          </div>
        ))}
        <a href="/contact" class="btn btn-accent w-full mt-4">Contact Us</a>
      </nav>
    </div>
  </div>
</header>

<style is:global>
  /* Mobile drawer accordion: smooth height + fade via grid-template-rows trick. */
  .gt-acc {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.28s ease, opacity 0.28s ease;
  }
  .gt-acc[data-open='true'] {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  .gt-acc > div {
    overflow: hidden;
    min-height: 0;
  }
  [data-acc-toggle][aria-expanded='true'] .gt-chevron {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .gt-acc,
    .gt-chevron {
      transition: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const close = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-nav-backdrop');
  const nav = document.getElementById('mobile-nav');

  function openNav() {
    nav?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeNav() {
    nav?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openNav);
  close?.addEventListener('click', closeNav);
  backdrop?.addEventListener('click', closeNav);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !nav?.classList.contains('hidden')) closeNav();
  });

  // Accordion: collapsed by default, one section open at a time per sibling level.
  function setItemOpen(item: Element, open: boolean) {
    const toggle = item.querySelector<HTMLButtonElement>(':scope > [data-acc-toggle]');
    const region = item.querySelector<HTMLElement>(':scope > [data-acc-region]');
    if (!toggle || !region) return;
    toggle.setAttribute('aria-expanded', String(open));
    region.setAttribute('data-open', String(open));
    if (!open) {
      // Collapse any nested sections so they start fresh when reopened.
      region.querySelectorAll('[data-acc-item]').forEach((child) => setItemOpen(child, false));
    }
  }

  nav?.querySelectorAll<HTMLButtonElement>('[data-acc-toggle]').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const item = toggle.closest('[data-acc-item]');
      if (!item) return;
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (!isOpen) {
        // Close sibling sections at the same level for a compact, scannable menu.
        const parent = item.parentElement;
        parent?.querySelectorAll(':scope > [data-acc-item]').forEach((sibling) => {
          if (sibling !== item) setItemOpen(sibling, false);
        });
      }
      setItemOpen(item, !isOpen);
    });
  });

  // Reset all sections to collapsed whenever the drawer is closed.
  function collapseAll() {
    nav?.querySelectorAll('[data-acc-item]').forEach((item) => setItemOpen(item, false));
  }
  close?.addEventListener('click', collapseAll);
  backdrop?.addEventListener('click', collapseAll);
</script>
