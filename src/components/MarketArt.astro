---
/*
 * Reusable, decorative line-art "scenes" — one per market.
 * Shared visual language across the set:
 *   - 320x200 (16:10) viewBox, single brand slate-blue via currentColor
 *   - consistent 2px main / 1.6px secondary line weight, round caps/joins
 *   - signature concentric quarter-arcs anchored to the bottom-right corner
 *   - a soft brand "glow" behind the focal motif + one solid brand focal dot
 *   - the recurring theme of *bent / curved glass* in every composition
 *
 * Consumed by MarketCard (homepage tiles), product category landing pages,
 * and the Inspection section — artwork stays in a single place with no duplication.
 */

type Market = 'solar' | 'automotive' | 'architectural' | 'aftermarket' | 'inspection';

interface Props {
  market: Market;
  class?: string;
  style?: string;
}

const { market, class: className = 'absolute inset-0 h-full w-full', style } = Astro.props;

const arcs = `
  <g stroke-opacity="0.1" stroke-width="2">
    <path d="M180 200 A140 140 0 0 1 320 60"/>
    <path d="M210 200 A110 110 0 0 1 320 90"/>
    <path d="M240 200 A80 80 0 0 1 320 120"/>
  </g>`;

const glow = (id: string, cx: number, cy: number, r: number) => `
  <defs>
    <radialGradient id="${id}" cx="50%" cy="50%" r="50%">
      <stop offset="0" stop-color="#45556c" stop-opacity="0.16"/>
      <stop offset="1" stop-color="#45556c" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <circle cx="${cx}" cy="${cy}" r="${r}" fill="url(#${id})" stroke="none"/>`;

const scenes: Record<Market, string> = {
  // SOLAR — concentrating parabolic mirror + sun, rays converging to a focal receiver
  solar: `
    ${glow('glow-solar', 165, 120, 80)}
    ${arcs}
    <g stroke-opacity="0.4" stroke-width="1.4">
      <path d="M95 156 L165 120"/>
      <path d="M165 178 L165 120"/>
      <path d="M235 156 L165 120"/>
    </g>
    <g stroke-opacity="0.55">
      <path d="M52 150 Q165 196 278 150"/>
    </g>
    <g stroke-opacity="0.35" stroke-width="1.6">
      <path d="M62 142 Q165 184 268 142"/>
    </g>
    <g stroke-opacity="0.55"><circle cx="74" cy="58" r="13"/></g>
    <g stroke-opacity="0.4" stroke-width="1.6">
      <path d="M91 58 H98"/><path d="M86 46 L91 41"/><path d="M74 41 V34"/>
      <path d="M62 46 L57 41"/><path d="M57 58 H50"/><path d="M62 70 L57 75"/>
      <path d="M74 75 V82"/><path d="M86 70 L91 75"/>
    </g>
    <circle cx="165" cy="120" r="4" fill="currentColor" stroke="none"/>`,

  // AUTOMOTIVE — a curved windshield lite cross-section over a forming-line conveyor
  automotive: `
    ${glow('glow-auto', 160, 96, 80)}
    ${arcs}
    <g stroke-opacity="0.3" stroke-width="1.6">
      <path d="M36 164 H284"/>
      <circle cx="80" cy="170" r="4"/><circle cx="135" cy="170" r="4"/>
      <circle cx="190" cy="170" r="4"/><circle cx="245" cy="170" r="4"/>
    </g>
    <g stroke-opacity="0.55">
      <path d="M48 152 C92 74 228 74 272 152"/>
    </g>
    <g stroke-opacity="0.35" stroke-width="1.6">
      <path d="M48 140 C92 66 228 66 272 140"/>
      <path d="M48 152 V140"/><path d="M272 152 V140"/>
    </g>
    <circle cx="160" cy="84" r="4" fill="currentColor" stroke="none"/>`,

  // ARCHITECTURAL — a curved glass curtain wall with mullion grid + one lit pane
  architectural: `
    ${glow('glow-arch', 160, 104, 90)}
    ${arcs}
    <path d="M91 56 L125 52 L125 113 L91 113 Z" fill="#45556c" fill-opacity="0.12" stroke="none"/>
    <g stroke-opacity="0.55">
      <path d="M56 64 Q160 36 264 64"/>
      <path d="M56 176 Q160 152 264 176"/>
    </g>
    <g stroke-opacity="0.35" stroke-width="1.6">
      <path d="M56 120 Q160 96 264 120"/>
      <path d="M56 64 V176"/><path d="M91 56 V169"/><path d="M125 52 V165"/>
      <path d="M160 50 V164"/><path d="M195 52 V165"/><path d="M229 56 V169"/>
      <path d="M264 64 V176"/>
    </g>
    <circle cx="160" cy="50" r="4" fill="currentColor" stroke="none"/>`,

  // AFTERMARKET — a lifecycle/refresh loop encircling a small curved-glass part
  aftermarket: `
    ${glow('glow-after', 160, 104, 80)}
    ${arcs}
    <g stroke-opacity="0.3" stroke-width="1.6">
      <path d="M160 164 V170"/><path d="M140 160 L136 166"/><path d="M180 160 L184 166"/>
    </g>
    <g stroke-opacity="0.55">
      <path d="M160 52 A52 52 0 1 1 124 68"/>
      <path d="M124 68 L118 57"/><path d="M124 68 L134 62"/>
    </g>
    <g stroke-opacity="0.4" stroke-width="1.4">
      <path d="M139 96 Q160 89 181 96"/>
      <path d="M139 122 Q160 115 181 122"/>
      <path d="M139 96 V122"/><path d="M160 91 V120"/><path d="M181 96 V122"/>
    </g>
    <circle cx="160" cy="106" r="3.6" fill="currentColor" stroke="none"/>`,

  // INSPECTION — curved glass lite with transmitted scan beam, distortion grid, and gauge scale
  inspection: `
    ${glow('glow-insp', 162, 100, 82)}
    ${arcs}
    <g stroke-opacity="0.35" stroke-width="1.6">
      <path d="M40 88 H76"/><path d="M40 100 H76"/><path d="M40 112 H76"/>
    </g>
    <g stroke-opacity="0.45">
      <path d="M68 76 V124"/>
      <path d="M68 88 Q58 100 68 112"/>
    </g>
    <g stroke-opacity="0.55">
      <path d="M76 148 C100 68 220 68 244 148"/>
    </g>
    <g stroke-opacity="0.35" stroke-width="1.6">
      <path d="M76 136 C100 60 220 60 244 136"/>
      <path d="M76 148 V136"/><path d="M244 148 V136"/>
    </g>
    <g stroke-opacity="0.35" stroke-width="1.4">
      <path d="M100 96 V134"/>
      <path d="M132 92 V138"/>
      <path d="M160 90 V140"/>
      <path d="M188 92 V138"/>
      <path d="M220 96 V134"/>
      <path d="M92 108 Q160 102 228 108"/>
      <path d="M90 122 Q160 116 230 122"/>
    </g>
    <g stroke-opacity="0.5" stroke-width="1.6">
      <path d="M76 100 H244"/>
    </g>
    <g stroke-opacity="0.3" stroke-width="1.6">
      <path d="M268 72 V148"/>
      <path d="M264 84 H272"/><path d="M264 108 H272"/><path d="M264 132 H272"/>
    </g>
    <circle cx="160" cy="90" r="4" fill="currentColor" stroke="none"/>`,
};

const scene = scenes[market] ?? scenes.solar;
---

<svg
  class:list={['text-brand', className]}
  style={style}
  viewBox="0 0 320 200"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  set:html={scene}
></svg>
