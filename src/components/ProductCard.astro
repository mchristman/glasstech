---
interface Props {
  title: string;
  href: string;
  description?: string;
}

const { title, href, description } = Astro.props;
---

<a
  href={href}
  class="group flex items-start justify-between gap-4 rounded-xl border border-slate-200 bg-white p-5 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50"
>
  <div class="min-w-0">
    <h3 class="font-semibold text-ink transition-colors group-hover:text-brand">{title}</h3>
    {description && <p class="mt-1.5 text-sm leading-6 text-muted line-clamp-2">{description}</p>}
  </div>
  <svg class="mt-1 h-4 w-4 shrink-0 text-slate-300 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
</a>
