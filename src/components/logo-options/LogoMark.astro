---
interface Props {
  variant: '1' | '2' | '3' | '4';
  class?: string;
}

const { variant, class: className = '' } = Astro.props;
---

<svg
  width="34"
  height="34"
  viewBox="0 0 34 34"
  fill="none"
  aria-hidden="true"
  class:list={['shrink-0', className]}
>
  {
    variant === '1' && (
      <>
        <path
          d="M 5 25 H 28"
          stroke="#45556c"
          stroke-opacity="0.16"
          stroke-width="1"
          stroke-linecap="round"
        />
        <path
          d="M 5 25 H 13.5 C 15.5 25 17 23 18.5 20 C 20.5 16 23.5 11.5 29 9"
          stroke="#45556c"
          stroke-width="2.85"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
      </>
    )
  }
  {
    variant === '2' && (
      <>
        <path
          d="M 7 26 C 7 13.5 17 5.5 27 10"
          stroke="#45556c"
          stroke-width="2.5"
          stroke-linecap="round"
          fill="none"
        />
        <path
          d="M 10 23.5 C 10 15 17 9.5 24 13"
          stroke="#45556c"
          stroke-width="2.5"
          stroke-linecap="round"
          fill="none"
        />
      </>
    )
  }
  {
    variant === '3' && (
      <>
        <defs>
          <linearGradient id={`opt3-heat-${variant}`} x1="17" y1="27" x2="17" y2="5" gradientUnits="userSpaceOnUse">
            <stop stop-color="#323d4e" />
            <stop offset="0.4" stop-color="#45556c" />
            <stop offset="1" stop-color="#8c98ab" />
          </linearGradient>
        </defs>
        <path
          d="M 5 25 Q 17 5.5 29 25"
          stroke={`url(#opt3-heat-${variant})`}
          stroke-width="3.2"
          stroke-linecap="round"
          fill="none"
        />
      </>
    )
  }
  {
    variant === '4' && (
      <>
        <path
          d="M 6 10.5 H 28"
          stroke="#45556c"
          stroke-width="2.5"
          stroke-linecap="round"
        />
        <path
          d="M 16.5 10.5 V 28"
          stroke="#45556c"
          stroke-width="2.5"
          stroke-linecap="round"
        />
        <path
          d="M 16.5 16.5 C 10.5 16.5 7.5 19.5 7.5 23.5 C 7.5 27.5 10.5 29.5 15 29.5 C 19 29.5 22.5 27 22.5 22.5 C 22.5 20.5 21 19 18.5 19 H 16.5"
          stroke="#45556c"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
      </>
    )
  }
</svg>
