---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Glasstech, Inc. — The leader in glass tempering and bending equipment. Servicing the Automotive, Architectural and Solar Markets.',
  image = '/images/about-glasstech.jpg',
} = Astro.props;
const fullTitle = title.includes('Glasstech') ? title : `${title} | Glasstech, Inc.`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Glasstech, Inc.',
  url: 'https://www.glasstech.com',
  logo: 'https://www.glasstech.com/favicon.svg',
  foundingDate: '1971',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '2744 Crossroads Parkway',
    addressLocality: 'Perrysburg',
    addressRegion: 'OH',
    postalCode: '43551',
    addressCountry: 'US',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-419-661-9500',
    contactType: 'customer service',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Glasstech, Inc." />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    {cfBeaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
      />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <slot name="header" />
    <main class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
