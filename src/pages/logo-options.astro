---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoLockup from '../components/logo-options/LogoLockup.astro';
import LogoMark from '../components/logo-options/LogoMark.astro';

const options = [
  {
    id: '1' as const,
    label: 'Option 1',
    title: 'Temper Line',
    description:
      'A bold horizontal line that transitions into a controlled curve — flat stock becoming bent glass under heat. Restrained, iconic, Paul Rand–level simplicity.',
    file: '/logos/option-1.svg',
  },
  {
    id: '2' as const,
    label: 'Option 2',
    title: 'Dual Lite',
    description:
      'Two parallel curved profiles with precise spacing — the cross-section of bent glass lites, evoking automotive and architectural forming without depicting machinery.',
    file: '/logos/option-2.svg',
  },
  {
    id: '3' as const,
    label: 'Option 3',
    title: 'Heat Arc',
    description:
      'A single thick arc with a thermal gradient — cool at the edges, lighter at the apex — suggesting the heat cycle of glass bending and tempering.',
    file: '/logos/option-3.svg',
  },
  {
    id: '4' as const,
    label: 'Option 4',
    title: 'GT Mark',
    description:
      'An interlocked G and T ligature with a shared vertical stem — reads as letterforms up close and as a bent glass profile at small sizes.',
    file: '/logos/option-4.svg',
  },
];

const navPlaceholder = ['Products', 'Markets', 'About', 'Contact'];
---

<BaseLayout
  title="Logo Options — Glasstech"
  description="Internal preview of alternative Glasstech logo mark concepts."
>
  <div class="border-b border-slate-200 bg-slate-50">
    <div class="container-x py-10 sm:py-14">
      <p class="eyebrow mb-3">Internal preview</p>
      <h1 class="text-3xl sm:text-4xl text-ink font-semibold tracking-tightest mb-3">
        Logo mark options — round 2
      </h1>
      <p class="text-body max-w-2xl text-pretty">
        Four new directions for the Glasstech header lockup. The live site still uses the
        current &ldquo;Formed Precision&rdquo; mark — pick a favorite here and we&rsquo;ll swap it in.
      </p>
    </div>
  </div>

  <div class="container-x py-10 sm:py-14">
    <div class="grid gap-10 lg:grid-cols-2">
      {
        options.map((option) => (
          <article class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-100 bg-white">
              <div class="flex items-baseline justify-between gap-3 flex-wrap">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand">
                    {option.label}
                  </p>
                  <h2 class="text-lg font-semibold text-ink mt-0.5">{option.title}</h2>
                </div>
                <a
                  href={option.file}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-muted hover:text-ink transition-colors"
                >
                  Mark SVG ↗
                </a>
              </div>
              <p class="text-sm text-muted mt-2">{option.description}</p>
            </div>

            <div class="border-b border-slate-200 bg-white/85 backdrop-blur-md">
              <div class="flex items-center justify-between h-16 lg:h-20 px-5 sm:px-6">
                <LogoLockup>
                  <LogoMark slot="mark" variant={option.id} />
                </LogoLockup>
                <nav class="hidden sm:flex items-center gap-3" aria-hidden="true">
                  {navPlaceholder.map((label) => (
                    <span class="text-[0.8rem] font-medium text-slate-400">{label}</span>
                  ))}
                </nav>
              </div>
            </div>

            <div class="px-5 py-5 bg-slate-50/80">
              <p class="text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-muted mb-3">
                Mark at small sizes
              </p>
              <div class="flex items-end gap-6">
                {[16, 24, 34].map((size) => (
                  <div class="flex flex-col items-center gap-1.5">
                    <img
                      src={option.file}
                      width={size}
                      height={size}
                      alt=""
                      class="block"
                    />
                    <span class="text-[0.6rem] text-muted tabular-nums">{size}px</span>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <p class="mt-12 text-sm text-muted text-center">
      Tell us which option you prefer (1, 2, 3, or 4) and we&rsquo;ll update
      <code class="text-xs bg-slate-100 px-1.5 py-0.5 rounded">Wordmark.astro</code>.
    </p>
  </div>
</BaseLayout>
