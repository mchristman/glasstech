---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import ToolingQuestionnaireForm from '../../../../components/ToolingQuestionnaireForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: 'Aftermarket', href: '/products/aftermarket' },
  { label: 'Tooling', href: '/products/aftermarket/tooling' },
  { label: 'Questionnaire', href: '/products/aftermarket/tooling/questionnaire' },
];
---

<BaseLayout
  title="Tool Design Questionnaire"
  description="Request a custom Glasstech tooling quote — complete our tool design questionnaire."
>
  <Header slot="header" />

  <PageHeader
    title="Tool design questionnaire"
    eyebrow="Aftermarket tooling"
    breadcrumbs={breadcrumbs}
    market="aftermarket"
  />

  <div class="container-x py-12 md:py-16">
    <div class="grid gap-14 lg:grid-cols-5">
      <div class="lg:col-span-3">
        <h2 class="text-2xl font-semibold text-ink">Complete the questionnaire</h2>
        <div class="mt-6">
          <ToolingQuestionnaireForm />
        </div>
      </div>

      <div class="lg:col-span-2">
        <h2 class="text-2xl font-semibold text-ink">Tooling information</h2>
        <div class="mt-6 space-y-4">
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <h3 class="font-semibold text-ink">Custom quotes</h3>
            <p class="mt-2 text-sm leading-6 text-muted">
              To receive a custom tooling quote, complete the questionnaire with as much detail as possible about your part specifications and requirements.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <h3 class="font-semibold text-ink">Math data</h3>
            <p class="mt-2 text-sm leading-6 text-muted">
              Required math data formats include IGES, CATIA v4 wireframe, or CATIA v4 surface including perimeter. Please e-mail math data files separately to{' '}
              <a href="mailto:tooling@glasstech.com" class="text-brand hover:text-ink transition-colors">tooling@glasstech.com</a>.
            </p>
            <p class="mt-2 text-sm leading-6 text-muted">
              Indicate whether data represents the inside or outside surface of the glass. Be sure to include paint band and heater data if applicable.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <h3 class="font-semibold text-ink">Contact</h3>
            <p class="mt-2 text-sm leading-6 text-muted">
              <span class="font-medium text-ink">Email</span>{' '}
              <a href="mailto:tooling@glasstech.com" class="text-brand hover:text-ink transition-colors">tooling@glasstech.com</a>
            </p>
            <p class="mt-3 text-sm leading-6 text-muted">
              Learn more about our tooling capabilities on the{' '}
              <a href="/products/aftermarket/tooling" class="text-brand hover:text-ink transition-colors">Tooling</a> page.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
