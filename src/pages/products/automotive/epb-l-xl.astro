---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PageHeader from '../../../components/PageHeader.astro';

const title = 'EPB-L™ | EPB-XL™ External Press Bending System';
const description =
  'The Glasstech EPB-L | EPB-XL external press bending system produces bent and annealed automotive windshields, backlites and sunroofs suitable for lamination, with superior optical quality and high productivity.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
  { label: 'Automotive', href: '/products/automotive' },
  { label: 'EPB-L/XL', href: '/products/automotive/epb-l-xl' },
];

const pdfs = [{ href: '/EPB-L_English.pdf', label: 'EPB-L | EPB-XL System (English)' }];

const productionCapabilities = [
  'Bent and annealed windshields, backlites and sunroofs suitable for lamination',
  'Compound, complex-shaped and cylindrical parts',
  'A single forming tool-set ensures high statistical repeatability',
  'Total energy consumption is significantly lower than conventional bending systems because the system only heats glass, instead of glass and bending rings',
  'In the EPB-XL configuration, capable of producing large panorama windshields and sunroofs',
];

const technicalFeatures = [
  {
    name: 'Load Table Positioner',
    detail:
      'Incorporates a computer-controlled servo positioning system which ensures correct positioning of inner or outer glass as it enters the heater.',
  },
  {
    name: 'Heater',
    detail:
      'The proven heater incorporates an energy-efficient design. Various convection options are available to heat different glass types.',
  },
  {
    name: 'Indexing Conveyor & FanRoll System',
    detail:
      'The final heating section is equipped with an indexing conveyor and FanRoll system that pre-forms the glass and rapidly transfers it to the pressing station, minimizing heat loss and improving the optical quality of the part.',
  },
  {
    name: 'Press Station',
    detail:
      'Utilizes precision, NC-machined tooling held at a constant temperature for consistent, repeatable quality, plus a full-perimeter press ring. Quick Change tooling and a roll-in/roll-out facility speed changeover, and an optional second press station can be prepared offline.',
  },
  {
    name: 'Annealer / Vacuum Pick-Up',
    detail:
      'Patented edge stress control provides edge compression three times higher than traditional methods while maintaining traditional inner band tension, reducing assembly and in-service breakage.',
  },
  {
    name: 'Cooler',
    detail: 'Requires no ductwork for efficient installation.',
  },
  {
    name: 'PC Interface',
    detail:
      'A user-friendly Allen-Bradley ControlLogix™ PLC controller regulates the conveyors, bending motion and part setup data, and provides online help and instant diagnostics.',
  },
  {
    name: 'Unloading Table',
    detail: 'For manual unloading or transfer to downstream processes.',
  },
];

