  { config: 'EPB-XL Standard Capacity', m: '21.2', ft: '69.5', g16: '9.5', c16: '17.2', g18: '10', c18: '19.4', g21: '11.7', c21: '22.7' },
  { config: 'EPB-XL Intermediate Capacity', m: '26.7', ft: '87.5', g16: '9.5', c16: '12.5', g18: '9.5', c18: '14.1', g21: '9.5', c21: '16.6' },
  { config: 'EPB-XL High Capacity', m: '34', ft: '111.5', g16: '9.5', c16: '9.5', g18: '9.5', c18: '10.4', g21: '9.5', c21: '12.1' },
