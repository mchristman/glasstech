  { config: 'EPB-L High Capacity', heaterM: '33.8', heaterFt: '110.7', totalM: '59', totalFt: '193.5', w1M: '12.2', w1Ft: '39.9', w2M: '18', w2Ft: '59', hM: '5.6', hFt: '18.4' },
  { config: 'EPB-L Coated High Capacity', heaterM: '39.2', heaterFt: '128.7', totalM: '64.5', totalFt: '211.5', w1M: '12.2', w1Ft: '39.9', w2M: '18', w2Ft: '59', hM: '5.6', hFt: '18.4' },
  { config: 'EPB-XL Standard Capacity', heaterM: '21.2', heaterFt: '69.5', totalM: '46.2', totalFt: '151.5', w1M: '16.8', w1Ft: '55', w2M: '22.2', w2Ft: '73', hM: '5.6', hFt: '18.4' },
  { config: 'EPB-XL Intermediate Capacity', heaterM: '26.7', heaterFt: '87.5', totalM: '54.7', totalFt: '179.5', w1M: '16.8', w1Ft: '55', w2M: '22.2', w2Ft: '73', hM: '5.6', hFt: '18.4' },
  { config: 'EPB-XL High Capacity', heaterM: '34', heaterFt: '111.5', totalM: '62', totalFt: '203.5', w1M: '16.8', w1Ft: '55', w2M: '22.2', w2Ft: '73', hM: '5.6', hFt: '18.4' },
  { config: 'EPB-XL Coated High Capacity', heaterM: '39.5', heaterFt: '129.5', totalM: '67.5', totalFt: '221.5', w1M: '16.8', w1Ft: '55', w2M: '22.2', w2Ft: '73', hM: '5.6', hFt: '18.4' },
];
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <PageHeader title={title} eyebrow="Automotive" breadcrumbs={breadcrumbs} market="automotive" />

  <div class="container-x py-12 md:py-16">
    <div class="prose-glasstech">
      <p>
        Glasstech&rsquo;s EPB-L system is an innovative, highly versatile glass bending system designed
        for the production of automotive laminated windshields and sunroofs. The system satisfies the
        automotive OEM demand for tighter surface tolerances with superior optical quality, while also
        meeting the glass processor&rsquo;s need for greater productivity, economical tooling and energy
        conservation.
      </p>
      <p>
        Designed as an expandable system, the production capabilities of the EPB-L can easily meet
        production needs. Production capabilities vary, with standard, intermediate and high capacity
        configurations available. Additionally, coated glass configurations are available to meet the
        increasing demand for processing high-performance coatings. In the highest capacity
        configuration, the EPB-L achieves a cycle time of 9.0 seconds for glass singles &mdash; enabling
        the two parts required for a windshield to be produced every 18 seconds.
      </p>
      <p>
        The system is available in a standard loading area of 1220&nbsp;mm x 1828&nbsp;mm (48&Prime; x
        72&Prime;) or an expanded loading area of 1600&nbsp;mm x 2134&nbsp;mm (63&Prime; x 84&Prime;).
      </p>
      <p>
        The Glasstech EPB-L utilizes patented features to provide high capability and quality parts. For
        example, the final heating section is equipped with a FanRoll system that is used to pre-form the
        glass before it arrives in the pressing station, providing an increase in forming capability. The
        EPB-L system also utilizes Glasstech&rsquo;s patented edge stress control technology, which
        increases edge strength while maintaining inner band tension &mdash; helping to reduce
        installation and in-service breakage.
      </p>

      <h2>Production Capabilities</h2>
      <ul>
        {productionCapabilities.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <section class="mt-14" aria-labelledby="features-heading">
      <h2 id="features-heading" class="text-xl md:text-2xl font-semibold text-ink">
        System Components &amp; Technical Features
      </h2>
      <dl class="mt-6 grid gap-px overflow-hidden rounded-2xl border border-slate-200 bg-slate-200 sm:grid-cols-2">
        {technicalFeatures.map((feature) => (
          <div class="bg-white p-5 sm:p-6">
            <dt class="text-sm font-semibold text-ink">{feature.name}</dt>
            <dd class="mt-2 text-sm leading-6 text-body">{feature.detail}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mt-14" aria-labelledby="specs-heading">
      <h2 id="specs-heading" class="text-xl md:text-2xl font-semibold text-ink">
        Technical Specifications
      </h2>

      <h3 class="mt-8 text-base font-semibold text-ink">Product Size and Forming Capability</h3>
      <div class="mt-3 overflow-x-auto rounded-xl border border-slate-200">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-ink">
              <th class="px-4 py-3 font-semibold" rowspan="2">System</th>
              <th class="px-4 py-3 font-semibold" rowspan="2">Thickness (mm)</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Min. Size (L x W)</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Max. Size (L x W)</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Depth of Bend</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Min. Radius</th>
            </tr>
            <tr class="bg-slate-50 text-left text-xs uppercase tracking-wide text-muted">
              <th class="px-4 py-2 font-medium">mm</th>
              <th class="px-4 py-2 font-medium">in</th>
              <th class="px-4 py-2 font-medium">mm</th>
              <th class="px-4 py-2 font-medium">in</th>
              <th class="px-4 py-2 font-medium">mm</th>
              <th class="px-4 py-2 font-medium">in</th>
              <th class="px-4 py-2 font-medium">mm</th>
              <th class="px-4 py-2 font-medium">in</th>
            </tr>
          </thead>
          <tbody>
            {sizeRows.map((row) => (
              <tr class="border-t border-slate-200">
                <th scope="row" class="px-4 py-3 text-left font-semibold text-ink">{row.model}</th>
                <td class="px-4 py-3 text-body">{row.thickness}</td>
                <td class="px-4 py-3 text-body">{row.minSizeMm}</td>
                <td class="px-4 py-3 text-body">{row.minSizeIn}</td>
                <td class="px-4 py-3 text-body">{row.maxSizeMm}</td>
                <td class="px-4 py-3 text-body">{row.maxSizeIn}</td>
                <td class="px-4 py-3 text-body">{row.depthMm}</td>
                <td class="px-4 py-3 text-body">{row.depthIn}</td>
                <td class="px-4 py-3 text-body">{row.radiusMm}</td>
                <td class="px-4 py-3 text-body">{row.radiusIn}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="mt-10 text-base font-semibold text-ink">Example System Configurations</h3>
      <p class="mt-2 text-sm text-muted">Cycle time in seconds by glass thickness.</p>
      <div class="mt-3 overflow-x-auto rounded-xl border border-slate-200">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-ink">
              <th class="px-4 py-3 font-semibold" rowspan="2">Configuration</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Heater Length</th>
              <th class="px-4 py-3 font-semibold" colspan="2">1.6&nbsp;mm</th>
              <th class="px-4 py-3 font-semibold" colspan="2">1.8&nbsp;mm</th>
              <th class="px-4 py-3 font-semibold" colspan="2">2.1&nbsp;mm</th>
            </tr>
            <tr class="bg-slate-50 text-left text-xs uppercase tracking-wide text-muted">
              <th class="px-4 py-2 font-medium">m</th>
              <th class="px-4 py-2 font-medium">ft</th>
              <th class="px-4 py-2 font-medium">Green</th>
              <th class="px-4 py-2 font-medium">Coated*</th>
              <th class="px-4 py-2 font-medium">Green</th>
              <th class="px-4 py-2 font-medium">Coated*</th>
              <th class="px-4 py-2 font-medium">Green</th>
              <th class="px-4 py-2 font-medium">Coated*</th>
            </tr>
          </thead>
          <tbody>
            {configRows.map((row) => (
              <tr class="border-t border-slate-200">
                <th scope="row" class="px-4 py-3 text-left font-semibold text-ink">{row.config}</th>
                <td class="px-4 py-3 text-body">{row.m}</td>
                <td class="px-4 py-3 text-body">{row.ft}</td>
                <td class="px-4 py-3 text-body">{row.g16}</td>
                <td class="px-4 py-3 text-body">{row.c16}</td>
                <td class="px-4 py-3 text-body">{row.g18}</td>
                <td class="px-4 py-3 text-body">{row.c18}</td>
                <td class="px-4 py-3 text-body">{row.g21}</td>
                <td class="px-4 py-3 text-body">{row.c21}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="mt-10 text-base font-semibold text-ink">Installed Electric Power</h3>
      <div class="mt-3 overflow-x-auto rounded-xl border border-slate-200">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-ink">
              <th class="px-4 py-3 font-semibold">Configuration</th>
              <th class="px-4 py-3 font-semibold">Heating (kW)</th>
              <th class="px-4 py-3 font-semibold">Annealing (kW)</th>
              <th class="px-4 py-3 font-semibold">Cooling (kW)</th>
              <th class="px-4 py-3 font-semibold">Drives (kW)</th>
              <th class="px-4 py-3 font-semibold">Total (kW)</th>
            </tr>
          </thead>
          <tbody>
            {powerRows.map((row) => (
              <tr class="border-t border-slate-200">
                <th scope="row" class="px-4 py-3 text-left font-semibold text-ink">{row.config}</th>
                <td class="px-4 py-3 text-body">{row.heating}</td>
                <td class="px-4 py-3 text-body">{row.annealing}</td>
                <td class="px-4 py-3 text-body">{row.cooling}</td>
                <td class="px-4 py-3 text-body">{row.drives}</td>
                <td class="px-4 py-3 font-medium text-ink">{row.total}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="mt-10 text-base font-semibold text-ink">Floor Space Requirements</h3>
      <div class="mt-3 overflow-x-auto rounded-xl border border-slate-200">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-ink">
              <th class="px-4 py-3 font-semibold" rowspan="2">Configuration</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Heater Length</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Total Length</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Total Width (1 Press)</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Total Width (2 Presses)</th>
              <th class="px-4 py-3 font-semibold" colspan="2">Height</th>
            </tr>
            <tr class="bg-slate-50 text-left text-xs uppercase tracking-wide text-muted">
              <th class="px-4 py-2 font-medium">m</th>
              <th class="px-4 py-2 font-medium">ft</th>
              <th class="px-4 py-2 font-medium">m</th>
              <th class="px-4 py-2 font-medium">ft</th>
              <th class="px-4 py-2 font-medium">m</th>
              <th class="px-4 py-2 font-medium">ft</th>
              <th class="px-4 py-2 font-medium">m</th>
              <th class="px-4 py-2 font-medium">ft</th>
              <th class="px-4 py-2 font-medium">m</th>
              <th class="px-4 py-2 font-medium">ft</th>
            </tr>
          </thead>
          <tbody>
            {floorRows.map((row) => (
              <tr class="border-t border-slate-200">
                <th scope="row" class="px-4 py-3 text-left font-semibold text-ink">{row.config}</th>
                <td class="px-4 py-3 text-body">{row.heaterM}</td>
                <td class="px-4 py-3 text-body">{row.heaterFt}</td>
                <td class="px-4 py-3 text-body">{row.totalM}</td>
                <td class="px-4 py-3 text-body">{row.totalFt}</td>
                <td class="px-4 py-3 text-body">{row.w1M}</td>
                <td class="px-4 py-3 text-body">{row.w1Ft}</td>
                <td class="px-4 py-3 text-body">{row.w2M}</td>
                <td class="px-4 py-3 text-body">{row.w2Ft}</td>
                <td class="px-4 py-3 text-body">{row.hM}</td>
                <td class="px-4 py-3 text-body">{row.hFt}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-4 text-xs leading-5 text-muted">
        *Requires smart convection option.<br />
        **Based on a 1&nbsp;m (39.3&Prime;) tall part size; taller parts have extended cycle time.
      </p>
    </section>

    <div class="mt-14 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
      <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-ink">Downloads</h2>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {pdfs.map((pdf) => (
          <a
            href={pdf.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-ink transition-colors hover:border-slate-300"
          >
            <span class="flex items-center gap-2.5">
              <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0 4-4m-4 4-4-4M5 19h14"/></svg>
              {pdf.label}
            </span>
            <svg class="h-4 w-4 text-slate-300 transition-colors group-hover:text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
