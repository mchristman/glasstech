  { config: 'EPB-L Standard Capacity', heaterM: '21', heaterFt: '68.9', totalM: '43.1', totalFt: '141.5', w1M: '12.2', w1Ft: '39.9', w2M: '18', w2Ft: '59', hM: '5.6', hFt: '18.4' },
